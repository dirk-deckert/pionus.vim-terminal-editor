{
  "name": "nvim-terminal-editor",
  "displayName": "Pionus Neovim Terminal Editor",
  "description": "Open the active VS Code file in Neovim inside a terminal editor with Pionus.",
  "version": "0.0.2",
  "publisher": "pionus",
  "license": "MIT",
  "homepage": "https://github.com/dirk-deckert/pionus.nvim-terminal-editor#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/dirk-deckert/pionus.nvim-terminal-editor.git"
  },
  "bugs": {
    "url": "https://github.com/dirk-deckert/pionus.nvim-terminal-editor/issues"
  },
  "keywords": [
    "pionus",
    "neovim",
    "terminal",
    "diagnostics",
    "preview"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:pionus.nvimTerminalEditor.openCurrentFile",
    "onCommand:pionus.nvimDiagnostics.goToFirst",
    "onCommand:pionus.nvimDiagnostics.goToLast",
    "onCommand:pionus.renderedPreview.openToSide",
    "onCommand:pionus.renderedPreview.close"
  ],
  "main": "./extension.js",
  "scripts": {
    "test": "node --test test/*.test.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2"
  },
  "contributes": {
    "commands": [
      {
        "command": "pionus.nvimTerminalEditor.openCurrentFile",
        "title": "Open Current File in Neovim Terminal Editor"
      },
      {
        "command": "pionus.nvimDiagnostics.goToFirst",
        "title": "Go to First Diagnostic in Current File"
      },
      {
        "command": "pionus.nvimDiagnostics.goToLast",
        "title": "Go to Last Diagnostic in Current File"
      },
      {
        "command": "pionus.renderedPreview.openToSide",
        "title": "Open Rendered Preview to the Side"
      },
      {
        "command": "pionus.renderedPreview.close",
        "title": "Close Rendered Preview"
      }
    ]
  }
}
