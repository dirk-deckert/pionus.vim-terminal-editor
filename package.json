{
  "name": "vim-terminal-editor",
  "displayName": "Pionus Vim Terminal Editor",
  "description": "Pionus Vim Terminal Editor opens the active VS Code file in Vim or Neovim inside a terminal.",
  "version": "0.1.3",
  "publisher": "pionus",
  "license": "MIT",
  "icon": "assets/icon.png",
  "homepage": "https://github.com/dirk-deckert/pionus.vim-terminal-editor#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/dirk-deckert/pionus.vim-terminal-editor.git"
  },
  "bugs": {
    "url": "https://github.com/dirk-deckert/pionus.vim-terminal-editor/issues"
  },
  "keywords": [
    "pionus",
    "vim",
    "neovim",
    "terminal",
    "diagnostics",
    "preview"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:pionus.vimTerminalEditor.openCurrentFile",
    "onCommand:pionus.nvimTerminalEditor.openCurrentFile",
    "onCommand:pionus.nvimDiagnostics.goToFirst",
    "onCommand:pionus.nvimDiagnostics.goToLast",
    "onCommand:pionus.renderedPreview.openToSide",
    "onCommand:pionus.renderedPreview.close"
  ],
  "main": "./extension.js",
  "scripts": {
    "test": "node --test test/*.test.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2"
  },
  "contributes": {
    "commands": [
      {
        "command": "pionus.vimTerminalEditor.openCurrentFile",
        "title": "Pionus Vim Terminal Editor: Open Current File"
      },
      {
        "command": "pionus.nvimDiagnostics.goToFirst",
        "title": "Pionus Vim Terminal Editor: Go to First Diagnostic"
      },
      {
        "command": "pionus.nvimDiagnostics.goToLast",
        "title": "Pionus Vim Terminal Editor: Go to Last Diagnostic"
      },
      {
        "command": "pionus.renderedPreview.openToSide",
        "title": "Pionus Vim Terminal Editor: Open Rendered Preview to the Side"
      },
      {
        "command": "pionus.renderedPreview.close",
        "title": "Pionus Vim Terminal Editor: Close Rendered Preview"
      }
    ],
    "configuration": {
      "title": "Pionus Vim Terminal Editor",
      "properties": {
        "pionus.vimTerminalEditor.editor": {
          "type": "string",
          "enum": [
            "vim",
            "nvim"
          ],
          "enumDescriptions": [
            "Use Vim.",
            "Use Neovim."
          ],
          "default": "vim",
          "description": "Select the editor used by Pionus Vim Terminal Editor."
        }
      }
    }
  }
}
